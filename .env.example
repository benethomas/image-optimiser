# Copy to .env and adjust. All values are optional; sensible defaults apply.

# Flask signing key. If unset, a random key is generated at startup (fine for
# dev, but it changes on every restart). Set a fixed one in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# Enable Flask debug mode + auto-reloader for local development (default: off).
# FLASK_DEBUG=1

# Dev server bind address (used by run.py only).
# HOST=127.0.0.1
# PORT=5000

# Max upload size is fixed at 25 MB in config. The rest are tunable:

# Where optimized files are written before download (defaults to a temp dir).
# UPLOAD_FOLDER=/var/tmp/image_optimiser

# How long an optimized file lives before the cleanup thread deletes it.
# FILE_TTL_SECONDS=900

# Rate-limit storage. Default is in-memory (single process only). Use a shared
# backend (e.g. Redis) when running multiple workers so counts are shared:
# RATELIMIT_STORAGE_URI=redis://localhost:6379
